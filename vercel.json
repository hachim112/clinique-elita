{
  "buildCommand": "python manage.py migrate --noinput && python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "clinique_elita/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "clinique_elita/wsgi.py"
    }
  ]
}
